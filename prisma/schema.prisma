generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationTrackingType {
  NONE // No location validation
  MANUAL // Manual selection
  GEO_FENCING // GPS-based radius check
  IP_WHITELIST // IP address validation
}

enum SalaryType {
  HOURLY // Paid per hour
  DAILY // Paid per day
  MONTHLY // Paid per month
}

enum BusinessSubscriptionStatus {
  TRIAL // During trial period before subscription starts
  ACTIVE // Active paid subscription
  EXPIRED // Subscription has ended (past endDate)
  CANCELLED // Manually cancelled by admin/user
  SUSPENDED // Temporarily suspended (payment issues, etc.)
  PENDING // Awaiting activation (before startDate)
}

enum NotificationTemplateStatus {
  DRAFT // Template in draft state
  ACTIVE // Active and can be used
  ARCHIVED // No longer in use
}

enum PayrollComponentStatus {
  DRAFT // Component in draft state
  ACTIVE // Active and can be used
  PUBLISHED // Published for use in payroll
  ARCHIVED // No longer in use
  DISABLED // Temporarily disabled
}

enum CommonStatus {
  DRAFT // Component in draft state
  ACTIVE // Active and can be used
  PUBLISHED // Published for use in payroll
  ARCHIVED // No longer in use
  DISABLED // Temporarily disabled
}

model User {
  id                    Int                @id @default(autoincrement())
  email                 String             @unique
  password              String
  status                String
  profile               Profile?           @relation(name: "userProfile")
  employee              Employee?          @relation(name: "userEmployee")
  roleId                Int                @map("role_id")
  role                  Role               @relation(fields: [roleId], references: [id], onDelete: Restrict)
  businessId            Int?               @map("business_id")
  business              Business?          @relation(name: "userBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  ownedBusiness         Business?          @relation(name: "ownedBusiness")
  userPermissions       UserPermission[]
  managedDepartments    Department[]       @relation(name: "managedDepartments")
  assetAssignments      AssetAssignment[]  @relation(name: "assetAssignmentsAssignedToUser")
  assetAssignmentsBy    AssetAssignment[]  @relation(name: "assetAssignmentsAssignedByUser")
  projectCreated        Project[]          @relation(name: "projectCreated")
  projects              ProjectMember[]    @relation(name: "projectMembersInUser")
  educationHistory      EducationHistory[] @relation(name: "userEducationHistory")
  jobHistory            JobHistory[]       @relation(name: "userJobHistory")
  scheduleAssignmentsBy EmployeeSchedule[] @relation(name: "scheduleAssignmentsByUser")
  documents             Document[]         @relation(name: "userDocuments")
  notes                 Note[]             @relation(name: "userNotes")
  notesCreated          Note[]             @relation(name: "noteCreatedBy")
  attendances           Attendance[]       @relation(name: "userAttendance")
  leaves                Leave[]            @relation(name: "userLeaves")
  reviewedLeaves        Leave[]            @relation(name: "leaveReviewedBy")
  payrollItems          PayrollItem[]      @relation(name: "userPayrollItems")
  notifications         Notification[]     @relation(name: "userNotifications")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([roleId])
  @@index([businessId])
  @@index([status])
  @@index([businessId, status])
  @@map("users")
}

model Profile {
  userId           Int               @id @map("user_id")
  user             User              @relation(name: "userProfile", fields: [userId], references: [id], onDelete: Cascade)
  fullName         String            @map("full_name")
  phone            String            @map("phone")
  profilePicture   String?           @map("profile_picture")
  dateOfBirth      DateTime          @map("date_of_birth") @db.Date
  gender           String            @map("gender")
  maritalStatus    String            @map("marital_status")
  address          String
  city             String
  country          String
  postcode         String
  emergencyContact EmergencyContact? @relation(name: "profileEmergencyContact")
  socialLink       SocialLink?       @relation(name: "profileSocialLinks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Business {
  id                    Int                    @id @default(autoincrement())
  name                  String
  email                 String
  phone                 String
  address               String
  country               String
  city                  String
  postcode              String
  registrationDate      DateTime               @map("registration_date") @db.Date
  status                String
  isSelfRegistered      Boolean                @default(false) @map("is_self_registered")
  ownerId               Int                    @unique @map("owner_id")
  owner                 User                   @relation(name: "ownedBusiness", fields: [ownerId], references: [id], onDelete: Cascade)
  features              BusinessFeature[]      @relation(name: "businessToFeatures")
  users                 User[]                 @relation(name: "userBusiness")
  roles                 Role[]                 @relation(name: "rolesInBusiness")
  businessSettings      BusinessSettings?      @relation(name: "businessSettings")
  leaveSettings         LeaveSettings?         @relation(name: "leaveSettings")
  attendanceSettings    AttendanceSettings?    @relation(name: "attendanceSettings")
  paymentSettings       PaymentSettings?       @relation(name: "paymentSettings")
  employmentStatuses    EmploymentStatus[]     @relation(name: "employmentStatusesInBusiness")
  designations          Designation[]          @relation(name: "designationsInBusiness")
  jobTypes              JobType[]              @relation(name: "jobTypesInBusiness")
  jobPlatforms          JobPlatform[]          @relation(name: "jobPlatformsInBusiness")
  recruitmentProcesses  RecruitmentProcess[]   @relation(name: "recruitmentProcessesInBusiness")
  onboardingProcesses   OnboardingProcess[]    @relation(name: "onboardingProcessesInBusiness")
  workSites             WorkSite[]             @relation(name: "workSitesInBusiness")
  departments           Department[]           @relation(name: "departmentsInBusiness")
  workSchedules         WorkSchedule[]         @relation(name: "workSchedulesInBusiness")
  businessSchedules     BusinessSchedule[]     @relation(name: "businessSchedules")
  leaveTypes            LeaveType[]            @relation(name: "leaveTypesInBusiness")
  subscriptions         BusinessSubscription[] @relation(name: "businessSubscriptions")
  assetTypes            AssetType[]            @relation(name: "assetTypesInBusiness")
  projects              Project[]              @relation(name: "projectsInBusiness")
  holidays              Holiday[]              @relation(name: "holidaysInBusiness")
  payrollComponents     PayrollComponent[]     @relation(name: "payrollComponentsInBusiness")
  payrollCycles         PayrollCycle[]         @relation(name: "payrollCyclesInBusiness")
  notifications         Notification[]         @relation(name: "businessNotifications")
  notificationTemplates NotificationTemplate[] @relation(name: "notificationTemplates")
  assets                Asset[]                @relation(name: "businessAssets")
  systemDefaults        SystemDefaults?        @relation(name: "businessSystemDefaults")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, email])
  @@index([ownerId])
  @@map("businesses")
}

model BusinessSettings {
  businessId              Int      @id @map("business_id")
  business                Business @relation(name: "businessSettings", fields: [businessId], references: [id], onDelete: Cascade)
  identifierPrefix        String   @map("identifier_prefix")
  businessStartDay        Int      @default(0) @map("business_start_day")
  currency                String   @default("BDT") @map("currency")
  businessTimeZone        String?  @default("Asia/Dhaka") @map("business_time_zone")
  deleteReadNotifications Int      @default(90) @map("delete_read_notifications")
  theme                   String?  @map("theme")
  googleApiKey            String?  @map("google_api_key")

  @@map("business_settings")
}

model AttendanceSettings {
  businessId                 Int      @id @map("business_id")
  business                   Business @relation(name: "attendanceSettings", fields: [businessId], references: [id], onDelete: Cascade)
  punchInTimeTolerance       Int      @default(15) @map("punch_in_time_tolerance")
  workAvailabilityDefinition Int      @default(80) @map("work_availability_definition")
  punchInOutAlert            Boolean  @default(true) @map("punch_in_out_alert")
  punchInOutInterval         Int      @default(1) @map("punch_in_out_interval")
  autoApproval               Boolean  @default(false) @map("auto_approval")
  isGeoFencingEnabled        Boolean  @default(false) @map("is_geo_fencing_enabled")

  @@map("attendance_settings")
}

model LeaveSettings {
  businessId   Int       @id @map("business_id")
  business     Business? @relation(name: "leaveSettings", fields: [businessId], references: [id], onDelete: Cascade)
  startMonth   Int       @default(0) @map("start_month")
  autoApproval Boolean   @default(false) @map("auto_approval")

  @@map("leave_settings")
}

model PaymentSettings {
  businessId           Int      @id @map("business_id")
  business             Business @relation(name: "paymentSettings", fields: [businessId], references: [id], onDelete: Cascade)
  paymentFrequency     String?  @map("payment_frequency")
  dayOfWeek            Int?     @map("day_of_week")
  dayOfMonth           Int?     @map("day_of_month")
  paymentMethod        String?  @map("payment_method")
  autoApprovePayments  Boolean  @default(false) @map("auto_approve_payments")
  gracePerDays         Int?     @default(3) @map("grace_period_days") // Days before payment to lock payroll
  allowPartialPayments Boolean  @default(false) @map("allow_partial_payments")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_settings")
}

model BusinessSchedule {
  id         Int      @id @default(autoincrement())
  dayOfWeek  Int      @map("day_of_week")
  isWeekend  Boolean  @map("is_weekend")
  startTime  String   @map("start_time") // Format: "HH:mm:ss"
  endTime    String   @map("end_time") // Format: "HH:mm:ss"
  businessId Int      @map("business_id")
  business   Business @relation(name: "businessSchedules", fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, dayOfWeek, startTime, endTime])
  @@index([businessId])
  @@map("business_schedules")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String
  businessId      Int?             @map("business_id")
  business        Business?        @relation(name: "rolesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  user            User[]
  rolePermissions RolePermission[]
  //  isAssignable Boolean @default(true) @map("is_assignable")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String //  "User", "Post", "Order"
  action   String //  "create", "read", "update", "delete"

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model SubscriptionPlan {
  id          Int                       @id @default(autoincrement())
  name        String                    @unique
  description String                    @db.Text
  setupFee    Int                       @map("setup_fee")
  status      String
  price       Int
  features    SubscriptionPlanFeature[] @relation(name: "PlanToFeature")
  subscribers BusinessSubscription[]    @relation(name: "subscriptionPlanInBusiness")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model Feature {
  id                Int                       @id @default(autoincrement())
  name              String                    @unique
  subscriptionPlans SubscriptionPlanFeature[] @relation(name: "FeatureToPlan")
  businesses        BusinessFeature[]         @relation(name: "FeatureToBusiness")

  @@map("features")
}

model SubscriptionPlanFeature {
  subscriptionPlanId Int
  featureId          Int

  subscriptionPlan SubscriptionPlan @relation(name: "PlanToFeature", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  feature          Feature          @relation(name: "FeatureToPlan", fields: [featureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([subscriptionPlanId, featureId])
  @@map("subscription_plan_features")
}

model BusinessFeature {
  businessId Int
  featureId  Int

  business Business @relation(name: "businessToFeatures", fields: [businessId], references: [id], onDelete: Cascade)
  feature  Feature  @relation(name: "FeatureToBusiness", fields: [featureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([businessId, featureId])
  @@map("business_features")
}

model BusinessSubscription {
  id                       Int                        @id @default(autoincrement())
  businessId               Int                        @map("business_id")
  business                 Business                   @relation(name: "businessSubscriptions", fields: [businessId], references: [id], onDelete: Cascade)
  subscriptionPlanId       Int                        @map("subscription_plan_id")
  subscriptionPlan         SubscriptionPlan           @relation(name: "subscriptionPlanInBusiness", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  trialEndDate             DateTime?                  @map("trial_end_date") @db.Date
  startDate                DateTime                   @map("start_date") @db.Date
  endDate                  DateTime?                  @map("end_date") @db.Date
  status                   BusinessSubscriptionStatus
  numberOfEmployeesAllowed Int                        @default(0) @map("number_of_employees_allowed")
  remarks                  String?                    @map("remarks") @db.Text
  notes                    String?                    @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, subscriptionPlanId])
  @@index([businessId])
  @@map("business_subscriptions")
}

model Designation {
  id          Int                   @id @default(autoincrement())
  name        String                @unique
  description String                @db.Text
  status      String
  businessId  Int                   @map("business_id")
  business    Business              @relation(name: "designationsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  employees   EmployeeDesignation[] @relation(name: "employeeDesignation")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("designations")
}

model EmployeeDesignation {
  userId        Int         @map("user_id")
  employee      Employee    @relation(name: "employeeDesignation", fields: [userId], references: [userId], onDelete: Cascade)
  designationId Int         @map("designation_id")
  designation   Designation @relation(name: "employeeDesignation", fields: [designationId], references: [id], onDelete: Cascade)
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime?   @map("end_date") @db.Date
  isActive      Boolean     @default(true) @map("is_active")
  remarks       String?     @map("remarks") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, designationId])
  @@index([userId])
  @@index([designationId])
  @@index([userId, isActive])
  @@index([startDate, endDate])
  @@map("employee_designations")
}

model JobType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  status      String
  businessId  Int      @map("business_id")
  business    Business @relation(name: "jobTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("job_types")
}

model JobPlatform {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String    @db.Text
  status      String
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobPlatformsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("job_platforms")
}

model RecruitmentProcess {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  status      String
  isRequired  Boolean  @map("is_required")
  businessId  Int      @map("business_id")
  business    Business @relation(name: "recruitmentProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("recruitment_processes")
}

model OnboardingProcess {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  status      String
  isRequired  Boolean  @map("is_required")
  businessId  Int      @map("business_id")
  business    Business @relation(name: "onboardingProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("onboarding_processes")
}

model WorkSite {
  id                       Int                  @id @default(autoincrement())
  name                     String               @unique
  description              String               @db.Text
  status                   String
  address                  String?
  lat                      Float?
  lng                      Float?
  locationTrackingType     LocationTrackingType @default(NONE) @map("location_tracking_type")
  maxRadius                Int?                 @map("max_radius")
  ipAddress                String?              @map("ip_address")
  businessId               Int                  @map("business_id")
  business                 Business             @relation(name: "workSitesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  attendancePunches        AttendancePunch[]    @relation(name: "attendancePunchWorkSite")
  employees                EmployeeWorkSite[]   @relation(name: "workSiteUsers")
  systemDefaultsAsWorkSite SystemDefaults[]     @relation(name: "defaultWorkSiteInSystemDefaults")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@index([status])
  @@map("work_sites")
}

model EmployeeWorkSite {
  userId     Int       @map("user_id")
  employee   Employee  @relation(name: "employeeWorkSites", fields: [userId], references: [userId], onDelete: Cascade)
  workSiteId Int       @map("work_site_id")
  workSite   WorkSite  @relation(name: "workSiteUsers", fields: [workSiteId], references: [id], onDelete: Cascade)
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  isActive   Boolean   @default(true) @map("is_active")
  remarks    String?   @map("remarks") @db.Text
  notes      String?   @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, workSiteId])
  @@index([userId])
  @@index([workSiteId])
  @@index([userId, isActive])
  @@index([startDate, endDate])
  @@map("user_work_sites")
}

model Department {
  id                         Int                  @id @default(autoincrement())
  parentId                   Int?                 @map("parent_id")
  parent                     Department?          @relation(name: "DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  name                       String               @unique
  description                String               @db.Text
  status                     String
  businessId                 Int                  @map("business_id")
  business                   Business             @relation(name: "departmentsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  managerId                  Int?                 @map("manager_id")
  manager                    User?                @relation(name: "managedDepartments", fields: [managerId], references: [id], onDelete: Restrict)
  children                   Department[]         @relation("DepartmentHierarchy")
  employees                  EmployeeDepartment[] @relation(name: "employeeDepartment")
  systemDefaultsAsDepartment SystemDefaults[]     @relation(name: "defaultDepartmentInSystemDefaults")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@index([managerId])
  @@index([parentId])
  @@index([status])
  @@map("departments")
}

model EmployeeDepartment {
  userId       Int        @map("user_id")
  employee     Employee   @relation(name: "employeeDepartment", fields: [userId], references: [userId], onDelete: Cascade)
  departmentId Int        @map("department_id")
  department   Department @relation(name: "employeeDepartment", fields: [departmentId], references: [id], onDelete: Cascade)
  startDate    DateTime   @map("start_date") @db.Date
  endDate      DateTime?  @map("end_date") @db.Date
  isPrimary    Boolean    @default(false) @map("is_primary")
  isActive     Boolean    @default(true) @map("is_active")
  roleInDept   String     @default("member") @map("role_in_dept")
  remarks      String?    @map("remarks") @db.Text
  notes        String?    @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@index([userId, isPrimary])
  @@index([userId, isActive])
  @@index([startDate, endDate])
  @@map("employee_departments")
}

model WorkSchedule {
  id                           Int                @id @default(autoincrement())
  name                         String             @unique
  description                  String             @db.Text
  status                       String
  scheduleType                 String
  breakType                    String
  breakMinutes                 Int                @default(0) @map("break_minutes")
  businessId                   Int                @map("business_id")
  business                     Business           @relation(name: "workSchedulesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  schedules                    DaySchedule[]      @relation(name: "daySchedule")
  employees                    EmployeeSchedule[] @relation(name: "workSchedules")
  systemDefaultsAsWorkSchedule SystemDefaults[]   @relation(name: "defaultWorkScheduleInSystemDefaults")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@index([status])
  @@index([scheduleType, businessId])
  @@map("work_schedules")
}

model EmployeeSchedule {
  userId         Int          @map("user_id")
  user           Employee     @relation(name: "employeeSchedules", fields: [userId], references: [userId], onDelete: Cascade)
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "workSchedules", fields: [workScheduleId], references: [id], onDelete: Restrict)
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime?    @map("end_date") @db.Date
  isActive       Boolean      @default(true) @map("is_active")
  assignedBy     Int          @map("assigned_by")
  assignedByUser User         @relation(name: "scheduleAssignmentsByUser", fields: [assignedBy], references: [id], onDelete: Restrict)
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, workScheduleId])
  @@index([userId])
  @@index([workScheduleId])
  @@index([userId, isActive])
  @@map("employee_schedules")
}

model DaySchedule {
  id             Int          @id @default(autoincrement())
  dayOfWeek      Int          @map("day_of_week") // dayOfWeek: 0 (Sunday) to 6 (Saturday)
  isWeekend      Boolean      @map("is_weekend")
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "daySchedule", fields: [workScheduleId], references: [id], onDelete: Cascade)
  timeSlots      TimeSlot[]   @relation(name: "shiftInSchedule")

  @@unique([workScheduleId, dayOfWeek])
  @@index([workScheduleId])
  @@map("work_day_schedules")
}

model TimeSlot {
  startTime  String      @map("start_time") // Format: "HH:mm:ss"
  endTime    String      @map("end_time") // Format: "HH:mm:ss"
  scheduleId Int         @map("schedule_id")
  schedule   DaySchedule @relation(name: "shiftInSchedule", fields: [scheduleId], references: [id], onDelete: Cascade)

  @@id([scheduleId, startTime, endTime])
  @@index([scheduleId])
  @@map("schedules_time_slots")
}

model EmploymentStatus {
  id          Int                         @id @default(autoincrement())
  name        String                      @unique
  description String                      @db.Text
  status      String
  leaveTypes  LeaveTypeEmploymentStatus[]
  businessId  Int                         @map("business_id")
  business    Business                    @relation(name: "employmentStatusesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  employees EmployeeStatus[] @relation(name: "employeeEmploymentStatus")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])

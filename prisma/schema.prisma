  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([payrollItemId, componentId])
  @@index([payrollItemId])
  @@index([componentId])
  @@map("payroll_item_components")
}

model PayslipAdjustment {
  id            Int         @id @default(autoincrement())
  payrollItemId Int         @map("payroll_item_id")
  payrollItem   PayrollItem @relation(name: "payslipAdjustments", fields: [payrollItemId], references: [id], onDelete: Cascade)
  type          String
  description   String
  amount        Float
  isRecurring   Boolean     @default(false) @map("is_recurring")
  createdBy     Int         @map("created_by")
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([payrollItemId])
  @@map("payslip_adjustments")
}

// ============ NOTIFICATION MANAGEMENT ============

model NotificationTemplate {
  id         Int       @id @default(autoincrement())
  name       String // "leave_approved", "payslip_generated", "attendance_late"
  type       String
  title      String // "Leave Request {{status}}"
  message    String // "Your leave from {{startDate}} to {{endDate}} has been {{status}}"
  priority   String
  channels   String[] // Default channels for this template
  isActive   Boolean   @default(true) @map("is_active")
  businessId Int?      @map("business_id")
  business   Business? @relation(name: "notificationTemplates", fields: [businessId], references: [id], onDelete: Cascade)

  notifications Notification[] @relation(name: "templateNotifications")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@index([type])
  @@map("notification_templates")
}

model Notification {
  id       Int    @id @default(autoincrement())
  type     String // What kind of notification
  title    String // Notification title (rendered from template or custom)
  message  String // Notification content (rendered from template or custom)
  priority String

  // Template relationship (optional - can be null for ad-hoc notifications)
  notificationTemplateId Int?                  @map("notification_template_id")
  notificationTemplate   NotificationTemplate? @relation(name: "templateNotifications", fields: [notificationTemplateId], references: [id], onDelete: SetNull)

  // Related entity (optional - for deep linking)
  entityType String? @map("entity_type") // "Leave", "Attendance", "Payroll"
  entityId   Int?    @map("entity_id") // ID of the related entity
  actionUrl  String? @map("action_url") // Deep link URL

  // Recipient
  userId Int  @map("user_id")
  user   User @relation(name: "userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  // Status tracking
  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  // Multi-channel delivery
  channels String[] // Which channels to send on
  sentVia  String[] @map("sent_via") // Which channels were actually sent

  // Business context
  businessId Int?      @map("business_id")
  business   Business? @relation(name: "businessNotifications", fields: [businessId], references: [id], onDelete: Cascade)

  // Metadata
  metadata  Json? // Additional data (JSON) - template variables, extra info
  expiresAt DateTime? @map("expires_at") // Optional expiry

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([businessId])
  @@index([type])
  @@index([notificationTemplateId])
  @@index([expiresAt])
  @@map("notifications")
}

model NotificationPreference {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(name: "userNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  // Channel preferences per notification type
  // Example: { "LEAVE": ["IN_APP", "EMAIL"], "PAYROLL": ["IN_APP", "EMAIL", "SMS"] }
  preferences Json

  // Global settings
  muteAll    Boolean   @default(false) @map("mute_all")
  mutedUntil DateTime? @map("muted_until") // Temporary mute

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

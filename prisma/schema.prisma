  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@index([type])
  @@index([status])
  @@map("notification_templates")
}

model Notification {
  id       Int    @id @default(autoincrement())
  type     String // What kind of notification
  title    String // Notification title (rendered from template or custom)
  message  String @db.Text // Notification content (rendered from template or custom)
  priority String

  // Template relationship (optional - can be null for ad-hoc notifications)
  notificationTemplateId Int?                  @map("notification_template_id")
  notificationTemplate   NotificationTemplate? @relation(name: "templateNotifications", fields: [notificationTemplateId], references: [id], onDelete: Restrict)

  // Related entity (optional - for deep linking)
  entityType String? @map("entity_type") // "Leave", "Attendance", "Payroll"
  entityId   Int?    @map("entity_id") // ID of the related entity

  // Recipient
  userId Int  @map("user_id")
  user   User @relation(name: "userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  // Status tracking
  readAt DateTime? @map("read_at")

  // Business context
  businessId Int      @map("business_id")
  business   Business @relation(name: "businessNotifications", fields: [businessId], references: [id], onDelete: Cascade)

  // Metadata
  metadata Json? // Additional data (JSON) - template variables, extra info

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([businessId])
  @@index([type])
  @@index([notificationTemplateId])
  @@map("notifications")
}

model SystemDefaults {
  businessId            Int          @id @map("business_id")
  business              Business     @relation(name: "businessSystemDefaults", fields: [businessId], references: [id], onDelete: Cascade)
  defaultDepartmentId   Int          @map("default_department_id")
  defaultDepartment     Department   @relation(name: "defaultDepartmentInSystemDefaults", fields: [defaultDepartmentId], references: [id], onDelete: Restrict)
  defaultWorkSiteId     Int          @map("default_work_site_id")
  defaultWorkSite       WorkSite     @relation(name: "defaultWorkSiteInSystemDefaults", fields: [defaultWorkSiteId], references: [id], onDelete: Restrict)
  defaultWorkScheduleId Int          @map("default_work_schedule_id")
  defaultWorkSchedule   WorkSchedule @relation(name: "defaultWorkScheduleInSystemDefaults", fields: [defaultWorkScheduleId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId])
  @@index([defaultDepartmentId])
  @@index([defaultWorkSiteId])
  @@index([defaultWorkScheduleId])
  @@map("system_defaults")
}

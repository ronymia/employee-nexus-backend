// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum USER_ACCOUNT_STATUS {
  Active
  Inactive
  Blocked
  Deleted
  Suspended
  Unverified
  Verified
  Terminated
  Resigned
  Retired
}

enum MARITAL_STATUS {
  Single
  Married
}

enum GENDER {
  Male
  Female
}

enum Status {
  Active
  Inactive
}

enum BusinessStatus {
  Active
  Inactive
  Suspended
  Trail_Expired
}

enum ScheduleType {
  Regular
  Scheduled
  Flexible
}

enum ScheduleBreakType {
  Paid
  Unpaid
}

enum DeleteReadNotifications {
  seven_days   @map("7_days")
  fifteen_days @map("15_days")
  thirty_days  @map("30_days")
}

model User {
  id                        Int                  @id @default(autoincrement())
  email                     String               @unique
  password                  String
  status                    USER_ACCOUNT_STATUS  @default(Verified)
  deletedBy                 Int?                 @map("deleted_by")
  profile                   Profile?             @relation(name: "userProfile")
  role                      Role?                @relation(fields: [roleId], references: [id])
  roleId                    Int                  @map("role_id")
  userPermissions           UserPermission[]
  business                  Business?            @relation(name: "businessOwner")
  servicePlanCreated        ServicePlan[]        @relation(name: "servicePlanCreated")
  employmentStatusCreated   EmploymentStatus[]   @relation(name: "employmentStatusCreated")
  designationCreated        Designation[]        @relation(name: "designationCreated")
  jobTypeCreated            JobType[]            @relation(name: "jobTypeCreated")
  jobPlatformCreated        JobPlatform[]        @relation(name: "jobPlatformCreated")
  recruitmentProcessCreated RecruitmentProcess[] @relation(name: "recruitmentProcessCreated")
  onboardingProcessCreated  OnboardingProcess[]  @relation(name: "onboardingProcessCreated")
  workLoSiteCreated         WorkLoSite[]         @relation(name: "workLoSiteCreated")
  workScheduleCreated       WorkSchedule[]       @relation(name: "workScheduleCreated")
  managedDepartments        Department[]         @relation(name: "managedDepartments")
  departmentCreated         Department[]         @relation(name: "departmentCreated")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Profile {
  id             Int            @id @default(autoincrement())
  full_name      String
  phone          String
  profilePicture String?        @map("profile_picture")
  dateOfBirth    DateTime       @map("date_of_birth")
  gender         GENDER
  maritalStatus  MARITAL_STATUS @map("marital_status")
  address        String
  city           String
  country        String
  postcode       String
  lat            Float?
  long           Float?
  user           User           @relation(name: "userProfile", fields: [userId], references: [id])
  userId         Int            @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Business {
  id                       Int                  @id @default(autoincrement())
  name                     String
  email                    String               @unique
  phone                    String               @unique
  address                  String
  country                  String
  city                     String
  postcode                 String
  lat                      Float?
  long                     Float?
  registrationDate         DateTime             @map("registration_date")
  website                  String?
  numberOfEmployeesAllowed Int                  @map("number_of_employees_allowed")
  isSubscribed             Boolean              @map("is_subscribed")
  trailEndDate             DateTime             @map("trail_end_date")
  status                   BusinessStatus       @default(Active)
  user                     User                 @relation(name: "businessOwner", fields: [userId], references: [id])
  userId                   Int                  @unique @map("user_id")
  servicePlan              ServicePlan          @relation(name: "businessServicePlan", fields: [servicePlanId], references: [id])
  servicePlanId            Int                  @map("service_plan_id")
  modules                  businessModule[]     @relation(name: "businessModules")
  roles                    Role[]               @relation(name: "rolesInBusiness")
  businessSettings         BusinessSettings?    @relation(name: "businessSettings")
  attendanceSettings       AttendanceSettings?  @relation(name: "attendanceSettings")
  employmentStatuses       EmploymentStatus[]   @relation(name: "employmentStatusesInBusiness")
  designations             Designation[]        @relation(name: "designationsInBusiness")
  jobTypes                 JobType[]            @relation(name: "jobTypesInBusiness")
  jobPlatforms             JobPlatform[]        @relation(name: "jobPlatformsInBusiness")
  recruitmentProcesses     RecruitmentProcess[] @relation(name: "recruitmentProcessesInBusiness")
  onboardingProcesses      OnboardingProcess[]  @relation(name: "onboardingProcessesInBusiness")
  workLoSites              WorkLoSite[]         @relation(name: "workLoSitesInBusiness")
  departments              Department[]         @relation(name: "departmentsInBusiness")
  workSchedules            WorkSchedule[]       @relation(name: "workSchedulesInBusiness")
  businessSchedule         BusinessSchedule[]   @relation(name: "businessSchedules")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("businesses")
}

model BusinessSettings {
  id                      Int                     @id @default(autoincrement())
  businessId              Int                     @unique @map("business_id")
  business                Business                @relation(name: "businessSettings", fields: [businessId], references: [id])
  identifierPrefix        String                  @map("identifier_prefix")
  businessStartDay        Int                     @default(0) @map("business_start_day")
  currency                String                  @default("BDT") @map("currency")
  isSelfRegistered        Boolean                 @default(false) @map("is_self_registered")
  businessTimeZone        String?                 @default("Asia/Dhaka") @map("business_time_zone")
  deleteReadNotifications DeleteReadNotifications @default(thirty_days) @map("delete_read_notifications")
  theme                   String?                 @map("theme")
}

model AttendanceSettings {
  id                   Int      @id @default(autoincrement())
  businessId           Int      @unique @map("business_id")
  business             Business @relation(name: "attendanceSettings", fields: [businessId], references: [id])
  punchInTimeTolerance Int      @default(15) @map("punch_in_time_tolerance")
  punchInOutAlert      Boolean  @default(true) @map("punch_in_out_alert")
  punchInOutInterval   Int      @default(1) @map("punch_in_out_interval")
  autoApproval         Boolean  @default(false) @map("auto_approval")
  isGeoLocationEnabled Boolean  @default(false) @map("is_geo_location_enabled")
}

model BusinessSchedule {
  id         Int      @id @default(autoincrement())
  day        Int
  isWeekend  Boolean  @map("is_weekend")
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  businessId Int      @map("business_id")
  business   Business @relation(name: "businessSchedules", fields: [businessId], references: [id])
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique // e.g., "super_admin", "admin", "manager"
  businessId      Int?             @map("business_id")
  business        Business?        @relation(name: "rolesInBusiness", fields: [businessId], references: [id])
  user            User[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String // e.g., "User", "Post", "Order"
  action   String // e.g., "create", "read", "update", "delete"

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model ServicePlan {
  id          Int                 @id @default(autoincrement())
  name        String              @unique
  description String
  setupFee    Int                 @map("setup_fee")
  status      String              @default("ACTIVE")
  price       Int
  businesses  Business[]          @relation(name: "businessServicePlan")
  modules     ServicePlanModule[] @relation(name: "servicePlanModules")
  createdBy   Int                 @map("created_by")
  creator     User?               @relation(name: "servicePlanCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_plans")
}

model SystemModule {
  id           Int                 @id @default(autoincrement())
  name         String              @unique
  isEnabled    Boolean             @default(true) @map("is_enabled")
  servicePlans ServicePlanModule[] @relation(name: "servicePlanInModules")
  businesses   businessModule[]    @relation(name: "businessInModules")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_modules")
}

model ServicePlanModule {
  servicePlanId  Int          @map("service_plan_id")
  servicePlan    ServicePlan  @relation(name: "servicePlanModules", fields: [servicePlanId], references: [id])
  systemModuleId Int          @map("system_module_id")
  systemModule   SystemModule @relation(name: "servicePlanInModules", fields: [systemModuleId], references: [id])
  isEnabled      Boolean      @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([servicePlanId, systemModuleId])
  @@map("service_plan_modules")
}

model businessModule {
  businessId     Int          @map("service_plan_id")
  business       Business     @relation(name: "businessModules", fields: [businessId], references: [id])
  systemModuleId Int          @map("system_module_id")
  systemModule   SystemModule @relation(name: "businessInModules", fields: [systemModuleId], references: [id])
  isEnabled      Boolean      @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, systemModuleId])
  @@map("business_modules")
}

model EmploymentStatus {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "employmentStatusesInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "employmentStatusCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("employment_statuses")
}

model Designation {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "designationsInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "designationCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("designations")
}

model JobType {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobTypesInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobTypeCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("job_types")
}

model JobPlatform {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobPlatformsInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobPlatformCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("job_platforms")
}

model RecruitmentProcess {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "recruitmentProcessesInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "recruitmentProcessCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("recruitment_processes")
}

model OnboardingProcess {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  status      Status    @default(Active)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "onboardingProcessesInBusiness", fields: [businessId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "onboardingProcessCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("onboarding_processes")
}

model WorkLoSite {
  id                   Int       @id @default(autoincrement())
  name                 String    @unique
  description          String
  status               Status    @default(Active)
  address              String?
  isLocationEnabled    Boolean?  @map("is_location_enabled")
  isGeoLocationEnabled Boolean?  @map("is_geo_location_enabled")
  maxRadius            Int?
  isIpEnabled          Boolean?  @map("is_ip_enabled")
  ipAddress            String?   @map("ip_address")
  businessId           Int?      @map("business_id")
  business             Business? @relation(name: "workLoSitesInBusiness", fields: [businessId], references: [id])
  createdBy            Int?      @map("created_by")
  creator              User?     @relation(name: "workLoSiteCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("work_sites")
}

model Department {
  id          Int       @id @default(autoincrement())
  parent_id   Int?
  name        String    @unique
  description String
  status      Status    @default(Active)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "departmentsInBusiness", fields: [businessId], references: [id])
  managerId   Int?      @map("manager_id")
  manager     User?     @relation(name: "managedDepartments", fields: [managerId], references: [id])
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "departmentCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model WorkSchedule {
  id           Int               @id @default(autoincrement())
  name         String            @unique
  description  String
  status       Status            @default(Active)
  scheduleType ScheduleType      @default(Regular)
  breakType    ScheduleBreakType @default(Unpaid) @map("break_type")
  breakHours   Int               @default(0) @map("break_hours")
  businessId   Int?              @map("business_id")
  business     Business?         @relation(name: "workSchedulesInBusiness", fields: [businessId], references: [id])
  createdBy    Int?              @map("created_by")
  creator      User?             @relation(name: "workScheduleCreated", fields: [createdBy], references: [id])
  schedules    Schedule[]        @relation(name: "workSchedule")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("work_schedules")
}

model Schedule {
  id             Int          @id @default(autoincrement())
  day            Int
  isWeekend      Boolean      @map("is_weekend")
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "workSchedule", fields: [workScheduleId], references: [id])
  shifts         Shift[]      @relation(name: "shiftInSchedule")
}

model Shift {
  id         Int      @id @default(autoincrement())
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  scheduleId Int      @map("schedule_id")
  schedule   Schedule @relation(name: "shiftInSchedule", fields: [scheduleId], references: [id])
}

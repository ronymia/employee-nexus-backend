model PayrollItemComponent {
  id              Int              @id @default(autoincrement())
  payrollItemId   Int              @map("payroll_item_id")
  payrollItem     PayrollItem      @relation(name: "payrollItemComponents", fields: [payrollItemId], references: [id], onDelete: Cascade)
  componentId     Int              @map("component_id")
  component       PayrollComponent @relation(name: "componentInPayrollItem", fields: [componentId], references: [id], onDelete: Restrict)
  amount          Float
  calculationBase Float?           @map("calculation_base") // calculation type eg : percentage base , fixed amount base
  notes           String?


  projectId      Int?       @map("project_id")
  project        Project?   @relation(name: "attendancePunchProject", fields: [projectId], references: [id], onDelete: SetNull)
  workSiteId     Int?       @map("work_site_id")
  workSite       WorkSite?  @relation(name: "attendancePunchWorkSite", fields: [workSiteId], references: [id], onDelete: SetNull)
  punchIn        DateTime   @map("punch_in") // Clock in timestamp
  punchOut       DateTime?  @map("punch_out") // Clock out timestamp (null if not clocked out yet)
  punchInBy      Int        @map("punch_in_by") // User ID who recorded the punch in (self or manager)
  punchOutBy     Int?       @map("punch_out_by") // User ID who recorded the punch out (self or manager)
  workMinutes    Int?       @map("work_minutes") // Calculated hours for this punch session
  breakMinutes   Int?       @map("break_minutes") // Calculated break hours for this punch session
  breakStart     DateTime?  @map("break_start") // Break start timestamp
  breakEnd       DateTime?  @map("break_end") // Break end timestamp
  punchInIp      String?    @map("punch_in_ip") // IP address used for punch in
  punchOutIp     String?    @map("punch_out_ip") // IP address used for punch out
  punchInLat     Float?     @map("punch_in_lat") // Punch in latitude
  punchInLng     Float?     @map("punch_in_lng") // Punch in longitude
  punchOutLat    Float?     @map("punch_out_lat") // Punch out latitude
  punchOutLng    Float?     @map("punch_out_lng") // Punch out longitude
  punchInDevice  String?    @map("punch_in_device") // Device info for punch in
  punchOutDevice String?    @map("punch_out_device") // Device info for punch out
  notes          String?    @map("notes") // Notes for this specific punch session

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([attendanceId])
  @@index([projectId])
  @@index([workSiteId])
  @@index([punchIn])
  @@map("attendance_punches")
}


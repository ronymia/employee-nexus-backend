// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum USER_ACCOUNT_STATUS {
  ACTIVE     @map("Active")
  INACTIVE   @map("Inactive")
  BLOCKED    @map("Blocked")
  DELETED    @map("Deleted")
  SUSPENDED  @map("Suspended")
  VERIFIED   @map("Verified")
  UNVERIFIED @map("Unverified")
  TERMINATED @map("Terminated")
  RESIGNED   @map("Resigned")
  RETIRED    @map("Retired")
  ON_LEAVE   @map("On_Leave")
}

enum MARITAL_STATUS {
  SINGLE  @map("Single")
  MARRIED @map("Married")
}

enum GENDER {
  MALE   @map("Male")
  FEMALE @map("Female")
}

enum Status {
  ACTIVE      @map("Active")
  INACTIVE    @map("Inactive")
  DEACTIVATED @map("Deactivated")
}

enum BusinessStatus {
  ACTIVE        @map("Active")
  INACTIVE      @map("Inactive")
  SUSPENDED     @map("Suspended")
  TRIAL_EXPIRED @map("Trial_Expired")
}

enum ScheduleType {
  REGULAR   @map("Regular")
  SCHEDULED @map("Scheduled")
  FLEXIBLE  @map("Flexible")
}

enum ScheduleBreakType {
  PAID   @map("Paid")
  UNPAID @map("Unpaid")
}

enum DeleteReadNotifications {
  SEVEN_DAYS   @map("7")
  FIFTEEN_DAYS @map("15")
  THIRTY_DAYS  @map("30")
}

enum LeaveRolloverType {
  NONE              @map("None")
  PARTIAL_ROLL_OVER @map("Partial_Rollover")
  FULL_ROLLOVER     @map("Full_Rollover")
}

enum SubscriptionStatus {
  ACTIVE    @map("Active")
  INACTIVE  @map("Inactive")
  TRIAL     @map("Trial")
  EXPIRED   @map("Expired")
  CANCELLED @map("Cancelled")
}

model User {
  id                        Int                  @id @default(autoincrement())
  email                     String               @unique
  password                  String
  status                    USER_ACCOUNT_STATUS  @default(UNVERIFIED)
  deletedBy                 Int?                 @map("deleted_by")
  profile                   Profile?             @relation(name: "userProfile")
  role                      Role?                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId                    Int?                 @map("role_id")
  userPermissions           UserPermission[]
  business                  Business?            @relation(name: "businessOwner")
  subscriptionPlanCreated   SubscriptionPlan[]   @relation(name: "subscriptionPlanCreated")
  employmentStatusCreated   EmploymentStatus[]   @relation(name: "employmentStatusCreated")
  designationCreated        Designation[]        @relation(name: "designationCreated")
  jobTypeCreated            JobType[]            @relation(name: "jobTypeCreated")
  jobPlatformCreated        JobPlatform[]        @relation(name: "jobPlatformCreated")
  recruitmentProcessCreated RecruitmentProcess[] @relation(name: "recruitmentProcessCreated")
  onboardingProcessCreated  OnboardingProcess[]  @relation(name: "onboardingProcessCreated")
  workSiteCreated           WorkSite[]           @relation(name: "workSiteCreated")
  workScheduleCreated       WorkSchedule[]       @relation(name: "workScheduleCreated")
  managedDepartments        Department[]         @relation(name: "managedDepartments")
  departmentCreated         Department[]         @relation(name: "departmentCreated")
  leaveTypeCreated          LeaveType[]          @relation(name: "leaveTypeCreated")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Profile {
  id             Int            @id @default(autoincrement())
  fullName       String         @map("full_name")
  phone          String
  profilePicture String?        @map("profile_picture")
  dateOfBirth    String         @map("date_of_birth")
  gender         GENDER
  maritalStatus  MARITAL_STATUS @map("marital_status")
  address        String
  city           String
  country        String
  postcode       String
  lat            Float?
  long           Float?
  user           User           @relation(name: "userProfile", fields: [userId], references: [id], onDelete: Cascade)
  userId         Int            @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Business {
  id                       Int     @id @default(autoincrement())
  name                     String
  email                    String
  phone                    String
  address                  String
  country                  String
  city                     String
  postcode                 String
  lat                      Float?
  long                     Float?
  registrationDate         String  @map("registration_date")
  website                  String?
  numberOfEmployeesAllowed Int     @map("number_of_employees_allowed")

  status               BusinessStatus         @default(ACTIVE)
  user                 User                   @relation(name: "businessOwner", fields: [userId], references: [id], onDelete: Cascade)
  userId               Int                    @unique @map("user_id")
  subscriptionPlan     SubscriptionPlan       @relation(name: "businessSubscriptionPlan", fields: [subscriptionPlanId], references: [id])
  subscriptionPlanId   Int                    @map("subscription_plan_id")
  modules              businessModule[]       @relation(name: "businessModules")
  roles                Role[]                 @relation(name: "rolesInBusiness")
  businessSettings     BusinessSettings?      @relation(name: "businessSettings")
  leaveSettings        LeaveSettings?         @relation(name: "leaveSettings")
  attendanceSettings   AttendanceSettings?    @relation(name: "attendanceSettings")
  PaymentSettings      PaymentSettings?       @relation(name: "paymentSettings")
  employmentStatuses   EmploymentStatus[]     @relation(name: "employmentStatusesInBusiness")
  designations         Designation[]          @relation(name: "designationsInBusiness")
  jobTypes             JobType[]              @relation(name: "jobTypesInBusiness")
  jobPlatforms         JobPlatform[]          @relation(name: "jobPlatformsInBusiness")
  recruitmentProcesses RecruitmentProcess[]   @relation(name: "recruitmentProcessesInBusiness")
  onboardingProcesses  OnboardingProcess[]    @relation(name: "onboardingProcessesInBusiness")
  workSites            WorkSite[]             @relation(name: "workSitesInBusiness")
  departments          Department[]           @relation(name: "departmentsInBusiness")
  workSchedules        WorkSchedule[]         @relation(name: "workSchedulesInBusiness")
  businessSchedule     BusinessSchedule[]     @relation(name: "businessSchedules")
  leaveTypes           LeaveType[]            @relation(name: "leaveTypesInBusiness")
  subscriptions        BusinessSubscription[] @relation(name: "businessSubscriptions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, userId, email])
  @@map("businesses")
}

model BusinessSettings {
  id                      Int                     @id @default(autoincrement())
  businessId              Int                     @unique @map("business_id")
  business                Business?               @relation(name: "businessSettings", fields: [businessId], references: [id], onDelete: Cascade)
  identifierPrefix        String                  @map("identifier_prefix")
  businessStartDay        Int                     @default(0) @map("business_start_day")
  currency                String                  @default("BDT") @map("currency")
  isSelfRegistered        Boolean                 @default(false) @map("is_self_registered")
  businessTimeZone        String?                 @default("Asia/Dhaka") @map("business_time_zone")
  deleteReadNotifications DeleteReadNotifications @default(THIRTY_DAYS) @map("delete_read_notifications")
  theme                   String?                 @map("theme")

  @@map("business_settings")
}

model AttendanceSettings {
  id                         Int       @id @default(autoincrement())
  businessId                 Int       @unique @map("business_id")
  business                   Business? @relation(name: "attendanceSettings", fields: [businessId], references: [id], onDelete: Cascade)
  punchInTimeTolerance       Int       @default(15) @map("punch_in_time_tolerance")
  workAvailabilityDefinition Int       @default(80) @map("work_availability_definition")
  punchInOutAlert            Boolean   @default(true) @map("punch_in_out_alert")
  punchInOutInterval         Int       @default(1) @map("punch_in_out_interval")
  autoApproval               Boolean   @default(false) @map("auto_approval")
  isGeoLocationEnabled       Boolean   @default(false) @map("is_geo_location_enabled")

  @@map("attendance_settings")
}

model LeaveSettings {
  id           Int       @id @default(autoincrement())
  businessId   Int       @unique @map("business_id")
  business     Business? @relation(name: "leaveSettings", fields: [businessId], references: [id], onDelete: Cascade)
  startMonth   Int       @default(0) @map("start_month")
  autoApproval Boolean   @default(false) @map("auto_approval")

  @@map("leave_settings")
}

model PaymentSettings {
  id          Int       @id @default(autoincrement())
  businessId  Int       @unique @map("business_id")
  business    Business? @relation(name: "paymentSettings", fields: [businessId], references: [id], onDelete: Cascade)
  paymentType String    @map("payment_type")
  dayOfWeek   Int?      @default(0) @map("day_of_week")
  dayOfMonth  Int?      @default(5) @map("day_of_month")

  @@map("payment_settings")
}

model BusinessSchedule {
  id         Int       @id @default(autoincrement())
  day        Int
  isWeekend  Boolean   @map("is_weekend")
  startTime  String    @map("start_time")
  endTime    String    @map("end_time")
  businessId Int       @unique @map("business_id")
  business   Business? @relation(name: "businessSchedules", fields: [businessId], references: [id], onDelete: Cascade)
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String // e.g., "super_admin", "admin", "manager"
  businessId      Int?             @map("business_id")
  business        Business?        @relation(name: "rolesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  user            User[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String //  "User", "Post", "Order"
  action   String //  "create", "read", "update", "delete"

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model SubscriptionPlan {
  id          Int                      @id @default(autoincrement())
  name        String                   @unique
  description String
  setupFee    Int                      @map("setup_fee")
  status      Status                   @default(ACTIVE)
  price       Int
  businesses  Business[]               @relation(name: "businessSubscriptionPlan")
  modules     SubscriptionPlanModule[] @relation(name: "subscriptionPlanModules")
  createdBy   Int                      @map("created_by")
  creator     User?                    @relation(name: "subscriptionPlanCreated", fields: [createdBy], references: [id], onDelete: Cascade)
  Businesses  BusinessSubscription[]   @relation(name: "subscriptionPlanInBusiness")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model SystemModule {
  id                Int                      @id @default(autoincrement())
  name              String                   @unique
  subscriptionPlans SubscriptionPlanModule[] @relation(name: "subscriptionPlanInSystemModules")
  businesses        businessModule[]         @relation(name: "businessInSystemModules")

  @@map("system_modules")
}

model SubscriptionPlanModule {
  subscriptionPlanId Int              @map("subscription_plan_id")
  subscriptionPlan   SubscriptionPlan @relation(name: "subscriptionPlanModules", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  systemModuleId     Int              @map("system_module_id")
  systemModule       SystemModule     @relation(name: "subscriptionPlanInSystemModules", fields: [systemModuleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([subscriptionPlanId, systemModuleId])
  @@map("subscription_plan_modules")
}

model businessModule {
  businessId     Int          @map("business_id")
  business       Business     @relation(name: "businessModules", fields: [businessId], references: [id], onDelete: Cascade)
  systemModuleId Int          @map("system_module_id")
  systemModule   SystemModule @relation(name: "businessInSystemModules", fields: [systemModuleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, systemModuleId])
  @@map("business_modules")
}

model BusinessSubscription {
  id                 Int                @id @default(autoincrement())
  businessId         Int                @map("business_id")
  business           Business           @relation(name: "businessSubscriptions", fields: [businessId], references: [id], onDelete: Cascade)
  subscriptionPlanId Int                @map("subscription_plan_id")
  SubscriptionPlan   SubscriptionPlan   @relation(name: "subscriptionPlanInBusiness", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  trialEndDate       String?            @map("trial_end_date")
  startDate          String?            @map("start_date")
  endDate            String?            @map("end_date")
  status             SubscriptionStatus @default(TRIAL)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([businessId, subscriptionPlanId])
  @@map("business_subscriptions")
}

model Designation {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "designationsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "designationCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("designations")
}

model JobType {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobTypeCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("job_types")
}

model JobPlatform {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobPlatformsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobPlatformCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("job_platforms")
}

model RecruitmentProcess {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "recruitmentProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "recruitmentProcessCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("recruitment_processes")
}

model OnboardingProcess {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "onboardingProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "onboardingProcessCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("onboarding_processes")
}

model WorkSite {
  id                   Int       @id @default(autoincrement())
  name                 String
  description          String
  status               Status    @default(ACTIVE)
  address              String?
  isLocationEnabled    Boolean?  @map("is_location_enabled")
  isGeoLocationEnabled Boolean?  @map("is_geo_location_enabled")
  maxRadius            Int?
  isIpEnabled          Boolean?  @map("is_ip_enabled")
  ipAddress            String?   @map("ip_address")
  businessId           Int?      @map("business_id")
  business             Business? @relation(name: "workSitesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy            Int?      @map("created_by")
  creator              User?     @relation(name: "workSiteCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("work_sites")
}

model Department {
  id          Int       @id @default(autoincrement())
  parent_id   Int?
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "departmentsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  managerId   Int?      @map("manager_id")
  manager     User?     @relation(name: "managedDepartments", fields: [managerId], references: [id], onDelete: Restrict)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "departmentCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([managerId])
  @@map("departments")
}

model WorkSchedule {
  id           Int               @id @default(autoincrement())
  name         String
  description  String
  status       Status            @default(ACTIVE)
  scheduleType ScheduleType      @default(REGULAR)
  breakType    ScheduleBreakType @default(UNPAID) @map("break_type")
  breakHours   Int               @default(0) @map("break_hours")
  businessId   Int?              @map("business_id")
  business     Business?         @relation(name: "workSchedulesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy    Int?              @map("created_by")
  creator      User?             @relation(name: "workScheduleCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  schedules    WorkDaySchedule[] @relation(name: "workSchedule")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([scheduleType])
  @@map("work_schedules")
}

model WorkDaySchedule {
  id             Int          @id @default(autoincrement())
  day            Int
  isWeekend      Boolean      @map("is_weekend")
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "workSchedule", fields: [workScheduleId], references: [id], onDelete: Cascade)
  shifts         Shift[]      @relation(name: "shiftInSchedule")

  @@unique([workScheduleId, day])
  @@map("work_day_schedules")
}

model Shift {
  id         Int             @id @default(autoincrement())
  startTime  String          @map("start_time")
  endTime    String          @map("end_time")
  scheduleId Int             @map("schedule_id")
  schedule   WorkDaySchedule @relation(name: "shiftInSchedule", fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, startTime, endTime])
  @@map("work_day_schedules_shifts")
}

model EmploymentStatus {
  id          Int                         @id @default(autoincrement())
  name        String
  description String
  status      Status                      @default(ACTIVE)
  leaveTypes  LeaveTypeEmploymentStatus[]
  businessId  Int?                        @map("business_id")
  business    Business?                   @relation(name: "employmentStatusesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?                        @map("created_by")
  creator     User?                       @relation(name: "employmentStatusCreated", fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("employment_statuses")
}

model LeaveTypeEmploymentStatus {
  leaveTypeId        Int @map("leave_type_id")
  employmentStatusId Int @map("employment_status_id")

  leaveType        LeaveType        @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  employmentStatus EmploymentStatus @relation(fields: [employmentStatusId], references: [id], onDelete: Restrict)

  @@unique([leaveTypeId, employmentStatusId])
  @@map("leave_type_employment_status")
}

model LeaveType {
  id                 Int                         @id @default(autoincrement())
  name               String
  leaveType          String                      @map("leave_type")
  leaveHours         Int                         @default(0) @map("leave_hours")
  leaveRolloverType  LeaveRolloverType           @default(NONE) @map("leave_rollover_type")
  carryOverLimit     Int?                        @map("carry_over_limit")
  status             Status                      @default(ACTIVE)
  employmentStatuses LeaveTypeEmploymentStatus[]
  businessId         Int?                        @map("business_id")
  business           Business?                   @relation(name: "leaveTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy          Int?                        @map("created_by")
  creator            User?                       @relation(name: "leaveTypeCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("leave_types")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserAccountStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
  SUSPENDED
  VERIFIED
  UNVERIFIED
  TERMINATED
  RESIGNED
  RETIRED
  ON_LEAVE
}

enum MaritalStatus {
  SINGLE
  MARRIED
}

enum Gender {
  MALE
  FEMALE
}

enum Status {
  ACTIVE
  INACTIVE
  DEACTIVATED
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL_EXPIRED
}

enum ScheduleType {
  REGULAR
  SCHEDULED
  FLEXIBLE
}

enum ScheduleBreakType {
  PAID
  UNPAID
}

/**
 * Better as an Int column rather than enum.
 * If you must keep enum, use semantic names — but prefer Int:
 * deleteReadNotificationsDays Int @default(30)
 */

enum LeaveRolloverType {
  NONE
  PARTIAL_ROLLOVER
  FULL_ROLLOVER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

enum LeaveDuration {
  SINGLE_DAY
  MULTI_DAY
  HALF_DAY
}

enum HolidayType {
  PUBLIC
  RELIGIOUS
  COMPANY_SPECIFIC
  REGIONAL
}

model User {
  id        Int               @id @default(autoincrement())
  email     String            @unique
  password  String
  status    UserAccountStatus @default(UNVERIFIED)
  deletedBy Int?              @map("deleted_by")
  profile   Profile?          @relation(name: "userProfile")

  employee Employee? @relation(name: "userEmployee")

  // Don't delete users when a role row is deleted
  role   Role? @relation(fields: [roleId], references: [id], onDelete: Restrict)
  roleId Int?  @map("role_id")

  // Direct business connection (optional for employees/managers/admins)
  businessId Int?      @map("business_id")
  business   Business? @relation(name: "userBusiness", fields: [businessId], references: [id], onDelete: Cascade)

  userPermissions           UserPermission[]
  ownedBusiness             Business?                    @relation(name: "businessOwner")
  subscriptionPlanCreated   SubscriptionPlan[]           @relation(name: "subscriptionPlanCreated")
  employmentStatusCreated   EmploymentStatus[]           @relation(name: "employmentStatusCreated")
  designationCreated        Designation[]                @relation(name: "designationCreated")
  jobTypeCreated            JobType[]                    @relation(name: "jobTypeCreated")
  jobPlatformCreated        JobPlatform[]                @relation(name: "jobPlatformCreated")
  recruitmentProcessCreated RecruitmentProcess[]         @relation(name: "recruitmentProcessCreated")
  onboardingProcessCreated  OnboardingProcess[]          @relation(name: "onboardingProcessCreated")
  workSiteCreated           WorkSite[]                   @relation(name: "workSiteCreated")
  workScheduleCreated       WorkSchedule[]               @relation(name: "workScheduleCreated")
  managedDepartments        Department[]                 @relation(name: "managedDepartments")
  departmentCreated         Department[]                 @relation(name: "departmentCreated")
  leaveTypeCreated          LeaveType[]                  @relation(name: "leaveTypeCreated")
  assetTypes                AssetType[]                  @relation(name: "assetTypesCreated")
  assetAssignments          AssetAssignment[]            @relation(name: "assetAssignmentsAssignedToUser")
  assetAssignmentsBy        AssetAssignment[]            @relation(name: "assetAssignmentsAssignedByUser")
  assetCreated              Asset[]                      @relation(name: "assetCreated")
  projectCreated            Project[]                    @relation(name: "projectCreated")
  projects                  ProjectMember[]              @relation(name: "projectMembersInUser")
  educationHistory          EducationHistory[]           @relation(name: "userEducationHistory")
  jobHistory                JobHistory[]                 @relation(name: "userJobHistory")
  scheduleAssignments       EmployeeScheduleAssignment[] @relation(name: "userScheduleAssignments")
  scheduleAssignmentsBy     EmployeeScheduleAssignment[] @relation(name: "scheduleAssignmentsByUser")
  documents                 Document[]                   @relation(name: "userDocuments")
  notes                     Note[]                       @relation(name: "userNotes")
  notesCreated              Note[]                       @relation(name: "noteCreatedBy")
  attendances               Attendance[]                 @relation(name: "userAttendance")
  leaves                    Leave[]                      @relation(name: "userLeaves")
  reviewedLeaves            Leave[]                      @relation(name: "leaveReviewedBy")
  holidaysCreated           Holiday[]                    @relation(name: "holidayCreated")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Profile {
  id             Int           @id @default(autoincrement())
  fullName       String        @map("full_name")
  phone          String
  profilePicture String?       @map("profile_picture")
  dateOfBirth    String        @map("date_of_birth")
  gender         Gender
  maritalStatus  MaritalStatus @map("marital_status")
  address        String
  city           String
  country        String
  postcode       String
  lat            Float?
  lng            Float?
  user           User          @relation(name: "userProfile", fields: [userId], references: [id], onDelete: Cascade)
  userId         Int           @unique @map("user_id")

  emergencyContact EmergencyContact? @relation(name: "profileEmergencyContact")
  socialLinks      SocialLink[]      @relation(name: "profileSocialLinks")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Business {
  id                       Int     @id @default(autoincrement())
  name                     String
  email                    String
  phone                    String
  address                  String
  country                  String
  city                     String
  postcode                 String
  lat                      Float?
  lng                      Float?
  registrationDate         String  @map("registration_date")
  website                  String?
  numberOfEmployeesAllowed Int     @map("number_of_employees_allowed")

  status             BusinessStatus   @default(ACTIVE)
  owner              User             @relation(name: "businessOwner", fields: [userId], references: [id], onDelete: Cascade)
  userId             Int              @unique @map("user_id")
  subscriptionPlan   SubscriptionPlan @relation(name: "businessSubscriptionPlan", fields: [subscriptionPlanId], references: [id])
  subscriptionPlanId Int              @map("subscription_plan_id")

  // Features via join table
  features BusinessFeature[] @relation(name: "businessToFeatures")

  users                User[]                 @relation(name: "userBusiness")
  roles                Role[]                 @relation(name: "rolesInBusiness")
  businessSettings     BusinessSettings?      @relation(name: "businessSettings")
  leaveSettings        LeaveSettings?         @relation(name: "leaveSettings")
  attendanceSettings   AttendanceSettings?    @relation(name: "attendanceSettings")
  paymentSettings      PaymentSettings?       @relation(name: "paymentSettings")
  employmentStatuses   EmploymentStatus[]     @relation(name: "employmentStatusesInBusiness")
  designations         Designation[]          @relation(name: "designationsInBusiness")
  jobTypes             JobType[]              @relation(name: "jobTypesInBusiness")
  jobPlatforms         JobPlatform[]          @relation(name: "jobPlatformsInBusiness")
  recruitmentProcesses RecruitmentProcess[]   @relation(name: "recruitmentProcessesInBusiness")
  onboardingProcesses  OnboardingProcess[]    @relation(name: "onboardingProcessesInBusiness")
  workSites            WorkSite[]             @relation(name: "workSitesInBusiness")
  departments          Department[]           @relation(name: "departmentsInBusiness")
  workSchedules        WorkSchedule[]         @relation(name: "workSchedulesInBusiness")
  businessSchedules    BusinessSchedule[]     @relation(name: "businessSchedules")
  leaveTypes           LeaveType[]            @relation(name: "leaveTypesInBusiness")
  subscriptions        BusinessSubscription[] @relation(name: "businessSubscriptions")
  assetTypes           AssetType[]            @relation(name: "assetTypesInBusiness")
  projects             Project[]              @relation(name: "projectsInBusiness")
  holidays             Holiday[]              @relation(name: "holidaysInBusiness")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  assets    Asset[]  @relation(name: "businessAssets")

  @@unique([name, userId, email])
  @@map("businesses")
}

model BusinessSettings {
  id                      Int       @id @default(autoincrement())
  businessId              Int       @unique @map("business_id")
  business                Business? @relation(name: "businessSettings", fields: [businessId], references: [id], onDelete: Cascade)
  identifierPrefix        String    @map("identifier_prefix")
  businessStartDay        Int       @default(0) @map("business_start_day")
  currency                String    @default("BDT") @map("currency")
  isSelfRegistered        Boolean   @default(false) @map("is_self_registered")
  businessTimeZone        String?   @default("Asia/Dhaka") @map("business_time_zone")
  deleteReadNotifications String    @map("delete_read_notifications")
  theme                   String?   @map("theme")

  @@map("business_settings")
}

model AttendanceSettings {
  id                         Int       @id @default(autoincrement())
  businessId                 Int       @unique @map("business_id")
  business                   Business? @relation(name: "attendanceSettings", fields: [businessId], references: [id], onDelete: Cascade)
  punchInTimeTolerance       Int       @default(15) @map("punch_in_time_tolerance")
  workAvailabilityDefinition Int       @default(80) @map("work_availability_definition")
  punchInOutAlert            Boolean   @default(true) @map("punch_in_out_alert")
  punchInOutInterval         Int       @default(1) @map("punch_in_out_interval")
  autoApproval               Boolean   @default(false) @map("auto_approval")
  isGeoLocationEnabled       Boolean   @default(false) @map("is_geo_location_enabled")

  @@map("attendance_settings")
}

model LeaveSettings {
  id           Int       @id @default(autoincrement())
  businessId   Int       @unique @map("business_id")
  business     Business? @relation(name: "leaveSettings", fields: [businessId], references: [id], onDelete: Cascade)
  startMonth   Int       @default(0) @map("start_month")
  autoApproval Boolean   @default(false) @map("auto_approval")

  @@map("leave_settings")
}

model PaymentSettings {
  id          Int       @id @default(autoincrement())
  businessId  Int       @unique @map("business_id")
  business    Business? @relation(name: "paymentSettings", fields: [businessId], references: [id], onDelete: Cascade)
  paymentType String    @map("payment_type")
  dayOfWeek   Int?      @map("day_of_week")
  dayOfMonth  Int?      @map("day_of_month")

  @@map("payment_settings")
}

model BusinessSchedule {
  id         Int       @id @default(autoincrement())
  day        Int
  isWeekend  Boolean   @map("is_weekend")
  startTime  String    @map("start_time")
  endTime    String    @map("end_time")
  businessId Int       @map("business_id")
  business   Business? @relation(name: "businessSchedules", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, day, startTime, endTime])
  @@index([businessId])
  @@map("business_schedules")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String // e.g., "super_admin", "admin", "manager"
  businessId      Int?             @map("business_id")
  business        Business?        @relation(name: "rolesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  user            User[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String //  "User", "Post", "Order"
  action   String //  "create", "read", "update", "delete"

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model SubscriptionPlan {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String
  setupFee    Int    @map("setup_fee")
  status      Status @default(ACTIVE)
  price       Int

  businesses  Business[]                @relation(name: "businessSubscriptionPlan")
  features    SubscriptionPlanFeature[] @relation(name: "PlanToFeature")
  createdBy   Int                       @map("created_by")
  creator     User?                     @relation(name: "subscriptionPlanCreated", fields: [createdBy], references: [id], onDelete: Restrict)
  subscribers BusinessSubscription[]    @relation(name: "subscriptionPlanInBusiness")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subscription_plans")
}

model Feature {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Must match join side names
  subscriptionPlans SubscriptionPlanFeature[] @relation(name: "FeatureToPlan")
  businesses        BusinessFeature[]         @relation(name: "FeatureToBusiness")

  @@map("features")
}

model SubscriptionPlanFeature {
  subscriptionPlanId Int
  featureId          Int

  subscriptionPlan SubscriptionPlan @relation(name: "PlanToFeature", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  feature          Feature          @relation(name: "FeatureToPlan", fields: [featureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([subscriptionPlanId, featureId])
  @@map("subscription_plan_features")
}

model BusinessFeature {
  businessId Int
  featureId  Int

  business Business @relation(name: "businessToFeatures", fields: [businessId], references: [id], onDelete: Cascade)
  feature  Feature  @relation(name: "FeatureToBusiness", fields: [featureId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([businessId, featureId])
  @@map("business_features")
}

model BusinessSubscription {
  id                 Int                @id @default(autoincrement())
  businessId         Int                @map("business_id")
  business           Business           @relation(name: "businessSubscriptions", fields: [businessId], references: [id], onDelete: Cascade)
  subscriptionPlanId Int                @map("subscription_plan_id")
  SubscriptionPlan   SubscriptionPlan   @relation(name: "subscriptionPlanInBusiness", fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  trialEndDate       String?            @map("trial_end_date")
  startDate          String?            @map("start_date")
  endDate            String?            @map("end_date")
  status             SubscriptionStatus @default(TRIAL)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, subscriptionPlanId])
  @@index([businessId])
  @@map("business_subscriptions")
}

model Designation {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "designationsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "designationCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  employees Employee[] @relation(name: "employeeDesignation")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("designations")
}

model JobType {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobTypeCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("job_types")
}

model JobPlatform {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "jobPlatformsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "jobPlatformCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("job_platforms")
}

model RecruitmentProcess {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "recruitmentProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "recruitmentProcessCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("recruitment_processes")
}

model OnboardingProcess {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  isRequired  Boolean   @map("is_required")
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "onboardingProcessesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "onboardingProcessCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("onboarding_processes")
}

model WorkSite {
  id                   Int       @id @default(autoincrement())
  name                 String
  description          String
  status               Status    @default(ACTIVE)
  address              String?
  isLocationEnabled    Boolean?  @map("is_location_enabled")
  isGeoLocationEnabled Boolean?  @map("is_geo_location_enabled")
  maxRadius            Int?
  isIpEnabled          Boolean?  @map("is_ip_enabled")
  ipAddress            String?   @map("ip_address")
  businessId           Int?      @map("business_id")
  business             Business? @relation(name: "workSitesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy            Int?      @map("created_by")
  creator              User?     @relation(name: "workSiteCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  employees         Employee[]        @relation(name: "employeeWorkSite")
  attendancePunches AttendancePunch[] @relation(name: "attendancePunchWorkSite")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("work_sites")
}

model Department {
  id          Int          @id @default(autoincrement())
  parentId    Int?         @map("parent_id")
  parent      Department?  @relation(name: "DepartmentHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  name        String
  description String
  status      Status       @default(ACTIVE)
  businessId  Int?         @map("business_id")
  business    Business?    @relation(name: "departmentsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  managerId   Int?         @map("manager_id")
  manager     User?        @relation(name: "managedDepartments", fields: [managerId], references: [id], onDelete: Restrict)
  createdBy   Int?         @map("created_by")
  creator     User?        @relation(name: "departmentCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  children    Department[] @relation("DepartmentHierarchy")

  employees Employee[] @relation(name: "employeeDepartment")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([managerId])
  @@index([parentId])
  @@map("departments")
}

model WorkSchedule {
  id           Int               @id @default(autoincrement())
  name         String
  description  String
  status       Status            @default(ACTIVE)
  scheduleType ScheduleType      @default(REGULAR)
  breakType    ScheduleBreakType @default(UNPAID) @map("break_type")
  breakHours   Int               @default(0) @map("break_hours")
  businessId   Int?              @map("business_id")
  business     Business?         @relation(name: "workSchedulesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy    Int?              @map("created_by")
  creator      User?             @relation(name: "workScheduleCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  schedules    DaySchedule[]     @relation(name: "daySchedule")

  employees           Employee[]                   @relation(name: "employeeWorkSchedule")
  scheduleAssignments EmployeeScheduleAssignment[] @relation(name: "workScheduleAssignments")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([scheduleType, businessId])
  @@map("work_schedules")
}

model EmployeeScheduleAssignment {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  user           User         @relation(name: "userScheduleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "workScheduleAssignments", fields: [workScheduleId], references: [id], onDelete: Restrict)
  startDate      DateTime     @map("start_date") // When the assignment becomes effective
  endDate        DateTime?    @map("end_date") // When the assignment ends, null if current
  isActive       Boolean      @default(true) @map("is_active") // Whether this is the active schedule
  assignedBy     Int          @map("assigned_by")
  assignedByUser User         @relation(name: "scheduleAssignmentsByUser", fields: [assignedBy], references: [id], onDelete: SetNull)
  notes          String? // Optional notes about the assignment

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([workScheduleId])
  @@index([userId, isActive])
  @@map("employee_schedule_assignments")
}

model DaySchedule {
  id             Int          @id @default(autoincrement())
  day            Int
  isWeekend      Boolean      @map("is_weekend")
  workScheduleId Int          @map("work_schedule_id")
  workSchedule   WorkSchedule @relation(name: "daySchedule", fields: [workScheduleId], references: [id], onDelete: Cascade)
  timeSlots      TimeSlot[]   @relation(name: "shiftInSchedule")

  @@unique([workScheduleId, day])
  @@index([workScheduleId])
  @@map("work_day_schedules")
}

model TimeSlot {
  startTime  String      @map("start_time")
  endTime    String      @map("end_time")
  scheduleId Int         @map("schedule_id")
  schedule   DaySchedule @relation(name: "shiftInSchedule", fields: [scheduleId], references: [id], onDelete: Cascade)

  @@id([scheduleId, startTime, endTime])
  @@index([scheduleId])
  @@map("schedules_time_slots")
}

model EmploymentStatus {
  id          Int                         @id @default(autoincrement())
  name        String
  description String
  status      Status                      @default(ACTIVE)
  leaveTypes  LeaveTypeEmploymentStatus[]
  businessId  Int?                        @map("business_id")
  business    Business?                   @relation(name: "employmentStatusesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?                        @map("created_by")
  creator     User?                       @relation(name: "employmentStatusCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  employees Employee[] @relation(name: "employeeEmploymentStatus")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("employment_statuses")
}

model LeaveTypeEmploymentStatus {
  leaveTypeId        Int @map("leave_type_id")
  employmentStatusId Int @map("employment_status_id")

  leaveType        LeaveType        @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  employmentStatus EmploymentStatus @relation(fields: [employmentStatusId], references: [id], onDelete: Cascade)

  @@id([leaveTypeId, employmentStatusId])
  @@map("leave_type_employment_status")
}

model LeaveType {
  id                 Int                         @id @default(autoincrement())
  name               String
  leaveType          String                      @map("leave_type")
  leaveHours         Int                         @default(0) @map("leave_hours")
  leaveRolloverType  LeaveRolloverType           @default(NONE) @map("leave_rollover_type")
  carryOverLimit     Int?                        @map("carry_over_limit")
  status             Status                      @default(ACTIVE)
  employmentStatuses LeaveTypeEmploymentStatus[]
  businessId         Int?                        @map("business_id")
  business           Business?                   @relation(name: "leaveTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy          Int?                        @map("created_by")
  creator            User?                       @relation(name: "leaveTypeCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  leaves             Leave[]                     @relation(name: "leaveTypeInLeave")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("leave_types")
}

model AssetType {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      Status    @default(ACTIVE)
  businessId  Int?      @map("business_id")
  business    Business? @relation(name: "assetTypesInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?      @map("created_by")
  creator     User?     @relation(name: "assetTypesCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  assets      Asset[]   @relation(name: "assetTypesInAsset")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("asset_types")
}

model Asset {
  id               Int               @id @default(autoincrement())
  name             String
  code             String
  date             String
  note             String?
  assetTypeId      Int?              @map("asset_type_id")
  assetType        AssetType?        @relation(name: "assetTypesInAsset", fields: [assetTypeId], references: [id], onDelete: SetNull)
  image            String?
  status           String            @default("unassigned")
  businessId       Int?              @map("business_id")
  business         Business?         @relation(name: "businessAssets", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy        Int?              @map("created_by")
  creator          User?             @relation(name: "assetCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  assetAssignments AssetAssignment[] @relation(name: "assetAssignmentsInAsset")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("assets")
}

model AssetAssignment {
  id             Int       @id @default(autoincrement())
  assetId        Int       @map("asset_id")
  asset          Asset     @relation(name: "assetAssignmentsInAsset", fields: [assetId], references: [id], onDelete: Cascade)
  assignedTo     Int       @map("assigned_to")
  assignedToUser User      @relation(name: "assetAssignmentsAssignedToUser", fields: [assignedTo], references: [id], onDelete: Cascade)
  assignedBy     Int       @map("assigned_by")
  assignedByUser User      @relation(name: "assetAssignmentsAssignedByUser", fields: [assignedBy], references: [id], onDelete: SetNull)
  assignedAt     DateTime  @default(now()) @map("assigned_at")
  returnedAt     DateTime? @map("returned_at")
  status         String    @default("assigned")
  note           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([assetId])
  @@index([assignedTo])
  @@index([assignedBy])
  @@map("asset_assignments")
}

model Project {
  id                Int               @id @default(autoincrement())
  name              String
  description       String?
  cover             String
  status            String
  startDate         String?           @map("start_date")
  endDate           String?           @map("end_date")
  businessId        Int               @map("business_id")
  business          Business?         @relation(name: "projectsInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy         Int?              @map("created_by")
  creator           User?             @relation(name: "projectCreated", fields: [createdBy], references: [id], onDelete: SetNull)
  projectMembers    ProjectMember[]   @relation(name: "projectMembersInProject")
  attendancePunches AttendancePunch[] @relation(name: "attendancePunchProject")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, businessId])
  @@index([businessId])
  @@map("projects")
}

model ProjectMember {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  project   Project @relation(name: "projectMembersInProject", fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int     @map("user_id")
  user      User    @relation(name: "projectMembersInUser", fields: [userId], references: [id], onDelete: Cascade)
  role      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Employee {
  id                  Int              @id @default(autoincrement())
  userId              Int              @unique @map("user_id")
  user                User             @relation(name: "userEmployee", fields: [userId], references: [id], onDelete: Cascade)
  employeeId          String           @unique @map("employee_id")
  nidNumber           String           @map("nid_number")
  joiningDate         DateTime         @map("joining_date")
  salaryPerMonth      Float            @map("salary_per_month")
  workingDaysPerWeek  Int?             @map("working_days_per_week")
  workingHoursPerWeek Int?             @map("working_hours_per_week")
  designationId       Int              @map("designation_id")
  designation         Designation      @relation(name: "employeeDesignation", fields: [designationId], references: [id])
  employmentStatusId  Int              @map("employment_status_id")
  employmentStatus    EmploymentStatus @relation(name: "employeeEmploymentStatus", fields: [employmentStatusId], references: [id])
  departmentId        Int              @map("department_id")
  department          Department       @relation(name: "employeeDepartment", fields: [departmentId], references: [id])
  workSiteId          Int              @map("work_site_id")
  workSite            WorkSite         @relation(name: "employeeWorkSite", fields: [workSiteId], references: [id])
  workScheduleId      Int              @map("work_schedule_id")
  workSchedule        WorkSchedule     @relation(name: "employeeWorkSchedule", fields: [workScheduleId], references: [id])
  rotaType            String           @default("day_base") @map("rota_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("employees")
}

model EmergencyContact {
  profileId Int     @id @map("profile_id")
  profile   Profile @relation(name: "profileEmergencyContact", fields: [profileId], references: [id], onDelete: Cascade)
  name      String  @map("name")
  phone     String  @map("phone")
  relation  String  @map("relation")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("emergency_contacts")
}

model EducationHistory {
  id                  Int     @id @default(autoincrement())
  userId              Int     @map("user_id")
  user                User    @relation(name: "userEducationHistory", fields: [userId], references: [id], onDelete: Cascade)
  degree              String // e.g., "Bachelor of Science", "Master of Arts", "High School Diploma"
  fieldOfStudy        String  @map("field_of_study") // e.g., "Computer Science", "Business Administration"
  institution         String // Name of school/university
  country             String // Country where institution is located
  city                String? // City where institution is located
  startDate           String  @map("start_date") // Format: "MM-YYYY" or "YYYY"
  endDate             String? @map("end_date") // Format: "MM-YYYY" or "YYYY", null if currently studying
  isCurrentlyStudying Boolean @default(false) @map("is_currently_studying")
  grade               String? // GPA, percentage, or grade classification
  description         String? // Additional details, achievements, or relevant coursework

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("education_history")
}

model JobHistory {
  id               Int     @id @default(autoincrement())
  userId           Int     @map("user_id")
  user             User    @relation(name: "userJobHistory", fields: [userId], references: [id], onDelete: Cascade)
  jobTitle         String  @map("job_title") // e.g., "Software Engineer", "Project Manager"
  companyName      String  @map("company_name") // Name of the company/organization
  employmentType   String  @map("employment_type") // e.g., "Full-time", "Part-time", "Contract", "Freelance"
  country          String // Country where job was located
  city             String? // City where job was located
  startDate        String  @map("start_date") // Format: "MM-YYYY" or "YYYY"
  endDate          String? @map("end_date") // Format: "MM-YYYY" or "YYYY", null if currently working
  responsibilities String? // Job responsibilities and duties
  achievements     String? // Key achievements and accomplishments

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("job_history")
}

model Document {
  id          Int     @id @default(autoincrement())
  userId      Int     @map("user_id")
  user        User    @relation(name: "userDocuments", fields: [userId], references: [id], onDelete: Cascade)
  title       String  @map("title")
  description String? @map("description")
  attachment  String  @map("attachment")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("documents")
}

model Note {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  user      User    @relation(name: "userNotes", fields: [userId], references: [id], onDelete: Cascade)
  createdBy Int     @map("created_by")
  creator   User    @relation(name: "noteCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  title     String  @map("title")
  content   String  @map("content")
  category  String? @map("category") // e.g., "Performance", "Incident", "General", "Feedback"
  isPrivate Boolean @default(true) @map("is_private")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([createdBy])
  @@map("notes")
}

model SocialLink {
  profileId Int     @id @map("profile_id")
  profile   Profile @relation(name: "profileSocialLinks", fields: [profileId], references: [id], onDelete: Cascade)
  facebook  String? @map("facebook")
  twitter   String? @map("twitter")
  linkedin  String? @map("linkedin")
  instagram String? @map("instagram")
  github    String? @map("github")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_links")
}

model Attendance {
  id           Int               @id @default(autoincrement())
  userId       Int               @map("user_id")
  user         User              @relation(name: "userAttendance", fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime          @map("date") // Date of attendance (stored as date only for grouping)
  totalHours   Float?            @map("total_hours") // Calculated total working hours for the day
  breakHours   Float?            @map("break_hours") // Calculated total break hours for the day
  status       String            @default("pending_approve") @map("status") // present, absent, late, half_day, on_leave
  punchRecords AttendancePunch[] @relation(name: "attendancePunchRecords")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("attendances")
}

model AttendancePunch {
  id             Int        @id @default(autoincrement())
  attendanceId   Int        @map("attendance_id")
  attendance     Attendance @relation(name: "attendancePunchRecords", fields: [attendanceId], references: [id], onDelete: Cascade)
  projectId      Int?       @map("project_id")
  project        Project?   @relation(name: "attendancePunchProject", fields: [projectId], references: [id], onDelete: SetNull)
  workSiteId     Int?       @map("work_site_id")
  workSite       WorkSite?  @relation(name: "attendancePunchWorkSite", fields: [workSiteId], references: [id], onDelete: SetNull)
  punchIn        DateTime   @map("punch_in") // Clock in timestamp
  punchOut       DateTime?  @map("punch_out") // Clock out timestamp (null if not clocked out yet)
  breakStart     DateTime?  @map("break_start") // Break start timestamp
  breakEnd       DateTime?  @map("break_end") // Break end timestamp
  workHours      Float?     @map("work_hours") // Calculated hours for this punch session
  breakHours     Float?     @map("break_hours") // Calculated break hours for this punch session
  punchInIp      String?    @map("punch_in_ip") // IP address used for punch in
  punchOutIp     String?    @map("punch_out_ip") // IP address used for punch out
  punchInLat     Float?     @map("punch_in_lat") // Punch in latitude
  punchInLng     Float?     @map("punch_in_lng") // Punch in longitude
  punchOutLat    Float?     @map("punch_out_lat") // Punch out latitude
  punchOutLng    Float?     @map("punch_out_lng") // Punch out longitude
  punchInDevice  String?    @map("punch_in_device") // Device info for punch in
  punchOutDevice String?    @map("punch_out_device") // Device info for punch out
  notes          String?    @map("notes") // Notes for this specific punch session

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([attendanceId])
  @@index([projectId])
  @@index([workSiteId])
  @@index([punchIn])
  @@map("attendance_punches")
}

model Leave {
  id              Int           @id @default(autoincrement())
  userId          Int           @map("user_id")
  user            User          @relation(name: "userLeaves", fields: [userId], references: [id], onDelete: Cascade)
  leaveTypeId     Int           @map("leave_type_id")
  leaveType       LeaveType     @relation(name: "leaveTypeInLeave", fields: [leaveTypeId], references: [id], onDelete: Restrict)
  leaveYear       Int           @map("leave_year") // Year this leave applies to (e.g., 2025)
  leaveDuration   LeaveDuration @map("leave_duration") // SINGLE_DAY, MULTI_DAY, HALF_DAY
  startDate       DateTime      @map("start_date") // Leave start date
  endDate         DateTime?     @map("end_date") // Leave end date (null for single day)
  totalHours      Float         @map("total_hours") // Total leave hours deducted from balance
  status          String        @default("pending") @map("status") // pending, approved, rejected, cancelled
  reviewedAt      DateTime?     @map("reviewed_at") // When leave was approved/rejected
  reviewedBy      Int?          @map("reviewed_by") // Manager/admin who reviewed
  reviewer        User?         @relation(name: "leaveReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  rejectionReason String?       @map("rejection_reason") // Reason for rejection if rejected
  attachments     String?       @map("attachments") // Supporting documents (JSON array or comma-separated URLs)
  notes           String?       @map("notes") // Additional notes or comments

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([leaveYear])
  @@index([startDate, endDate])
  @@index([userId, status])
  @@index([userId, leaveYear])
  @@map("leaves")
}

model Holiday {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime    @map("start_date") // Holiday start date
  endDate     DateTime    @map("end_date") // Holiday end date (same as startDate for single-day)
  isRecurring Boolean     @default(false) @map("is_recurring") // Annual recurring holiday
  isPaid      Boolean     @default(true) @map("is_paid") // Paid holiday or unpaid
  holidayType HolidayType @map("holiday_type") // PUBLIC, RELIGIOUS, COMPANY_SPECIFIC, REGIONAL
  businessId  Int?        @map("business_id")
  business    Business?   @relation(name: "holidaysInBusiness", fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   Int?        @map("created_by")
  creator     User?       @relation(name: "holidayCreated", fields: [createdBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([businessId])
  @@index([startDate, endDate])
  @@index([businessId, startDate])
  @@map("holidays")
}

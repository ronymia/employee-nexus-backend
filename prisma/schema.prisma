// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum USER_ACCOUNT_STATUS {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
  SUSPENDED
  UNVERIFIED
  VERIFIED
  TERMINATED
  RESIGNED
  RETIRED
}

enum MARITAL_STATUS {
  SINGLE
  MARRIED
}

enum GENDER {
  MALE
  FEMALE
}

model User {
  id              Int                 @id @default(autoincrement())
  email           String              @unique
  password        String
  status          USER_ACCOUNT_STATUS @default(UNVERIFIED)
  deletedBy       Int?                @map("deleted_by")
  profile         Profile?
  role            Role?               @relation(fields: [roleId], references: [id])
  roleId          Int                 @map("role_id")
  userPermissions UserPermission[]
  business        Business?
  servicePlans    ServicePlan[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Profile {
  id             Int      @id @default(autoincrement())
  full_name      String
  phone          String
  profilePicture String?  @map("profile_picture")
  dateOfBirth    DateTime @map("date_of_birth")
  gender         GENDER
  address        String
  city           String
  country        String
  postcode       String
  user           User     @relation(fields: [userId], references: [id])
  userId         Int      @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Business {
  id               Int              @id @default(autoincrement())
  name             String
  email            String           @unique
  phone            String           @unique
  address          String
  country          String
  city             String
  postcode         String
  registrationDate DateTime         @map("registration_date")
  website          String?
  user             User             @relation(fields: [userId], references: [id])
  userId           Int              @unique @map("user_id")
  servicePlan      ServicePlan      @relation(fields: [servicePlanId], references: [id])
  servicePlanId    Int              @map("service_plan_id")
  modules          businessModule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("businesses")
}

model Role {
  id              Int              @id @default(autoincrement())
  name            String           @unique // e.g., "super_admin", "admin", "manager"
  User            User[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String // e.g., "User", "Post", "Order"
  action   String // e.g., "create", "read", "update", "delete"

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       Int @map("user_id")
  permissionId Int @map("permission_id")

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model ServicePlan {
  id          Int                 @id @default(autoincrement())
  name        String              @unique
  description String
  setupFee    Int                 @map("setup_fee")
  status      String              @default("ACTIVE")
  price       Int
  businesses  Business[]
  modules     ServicePlanModule[]
  createdBy   Int                 @map("created_by")
  creator     User?               @relation(fields: [createdBy], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_plans")
}

model SystemModule {
  id           Int                 @id @default(autoincrement())
  name         String              @unique
  isEnabled    Boolean             @default(true) @map("is_enabled")
  servicePlans ServicePlanModule[]
  businesses   businessModule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_modules")
}

model ServicePlanModule {
  servicePlanId  Int          @map("service_plan_id")
  servicePlan    ServicePlan  @relation(fields: [servicePlanId], references: [id])
  systemModuleId Int          @map("system_module_id")
  systemModule   SystemModule @relation(fields: [systemModuleId], references: [id])
  isEnabled      Boolean      @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([servicePlanId, systemModuleId])
  @@map("service_plan_modules")
}

model businessModule {
  businessId     Int          @map("service_plan_id")
  business       Business     @relation(fields: [businessId], references: [id])
  systemModuleId Int          @map("system_module_id")
  systemModule   SystemModule @relation(fields: [systemModuleId], references: [id])
  isEnabled      Boolean      @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([businessId, systemModuleId])
  @@map("business_modules")
}

  netPay          Float        @map("net_pay")
  workingDays     Int          @map("working_days")
  presentDays     Float        @map("present_days")
  absentDays      Float        @map("absent_days")
  leaveDays       Float        @map("leave_days")
  overtimeHours   Float?       @map("overtime_hours")
  status          String
  paymentMethod   String       @map("payment_method")
  bankAccount     String?      @map("bank_account")
  transactionRef  String?      @map("transaction_ref")
  paidAt          DateTime?    @map("paid_at")
  notes           String?

  components  PayrollItemComponent[] @relation(name: "payrollItemComponents")
  adjustments PayslipAdjustment[]    @relation(name: "payslipAdjustments")

  createdAt DateTime @default(now()) @map("created_at")

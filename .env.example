DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=employee_management
DATABASE_USER=
DATABASE_PASSWORD=

DATABASE_URL=
PORT=4000
NODE_ENV=development
BCRYPT_SALT_ROUNDS=12

# Seed passwords — required only for local dev seeding. Never use weak passwords in production.
DEFAULT_SUPER_ADMIN_PASS=REPLACE_WITH_STRONG_PASSWORD
DEFAULT_BUSINESS_OWNER_PASS=REPLACE_WITH_STRONG_PASSWORD
DEFAULT_ADMIN_PASS=REPLACE_WITH_STRONG_PASSWORD
DEFAULT_MANAGER_PASS=REPLACE_WITH_STRONG_PASSWORD
DEFAULT_EMPLOYEE_PASS=REPLACE_WITH_STRONG_PASSWORD

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_TOKEN=REPLACE_WITH_STRONG_RANDOM_64_CHAR_HEX
JWT_REFRESH_TOKEN=REPLACE_WITH_STRONG_RANDOM_64_CHAR_HEX
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000